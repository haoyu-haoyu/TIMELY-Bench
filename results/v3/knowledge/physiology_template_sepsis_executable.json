  "atypical_variants": [
    {
      "variant_id": "sepsis_atyp_1",
      "name": "Lactate-low shock",
      "prevalence": "Clinically recognized subset of septic shock",
      "deviation": "Patient requires vasopressors with hypotension but lactate remains normal or only minimally elevated.",
      "clinical_implication": "Normal lactate should not be used to exclude hemodynamic compromise or shock physiology.",
      "cres_task": "Contrastive: distinguish vasopressor-requiring shock with low lactate from early sepsis without shock."
    },
    {
      "variant_id": "sepsis_atyp_2",
      "name": "Persistent multiorgan failure",
      "prevalence": "High-risk minority trajectory",
      "deviation": "SOFA burden remains elevated across multiple organ systems despite antibiotics and hemodynamic support.",
      "clinical_implication": "Represents non-resolving sepsis with high mortality risk and prolonged ICU dependency.",
      "cres_task": "Temporal reasoning: identify persistent non-recovering organ dysfunction rather than transient instability."
    },
    {
      "variant_id": "sepsis_atyp_3",
      "name": "Rapid hemodynamic recovery",
      "prevalence": "Common after effective early resuscitation in selected patients",
      "deviation": "MAP and vasopressor burden improve quickly, but residual organ dysfunction may lag behind.",
      "clinical_implication": "Hemodynamic stabilization does not necessarily mean full sepsis resolution.",
      "cres_task": "Temporal grounding: separate early cardiovascular recovery from slower overall organ recovery."
    }
