  "atypical_variants": [
    {
      "variant_id": "aki_atyp_1",
      "name": "Non-oliguric AKI",
      "prevalence": "~50% of ICU AKI episodes",
      "deviation": "Urine output remains >0.5 mL/kg/h throughout despite rising SCr and falling GFR",
      "clinical_implication": "UO-based KDIGO criteria not met; SCr-only diagnosis. May be missed if only monitoring UO.",
      "cres_task": "Contrastive: model must recognise AKI despite preserved urine output"
    },
    {
      "variant_id": "aki_atyp_2",
      "name": "Rapidly reversible (pre-renal) AKI",
      "prevalence": "~30-40% of AKI episodes",
      "deviation": "SCr peaks within 24-48h then declines rapidly with volume resuscitation. No sustained oliguric phase.",
      "clinical_implication": "Transient AKI; full recovery expected. Persistent AKI (>48h) suggests transition to ATN.",
      "cres_task": "Temporal grounding: model must distinguish transient from persistent trajectory"
    },
    {
      "variant_id": "aki_atyp_3",
      "name": "AKI on CKD (acute-on-chronic)",
      "prevalence": "~30% of AKI in elderly ICU patients",
      "deviation": "Elevated baseline SCr (e.g., 2.0 mg/dL). Absolute SCr rise smaller for same proportional GFR loss. Recovery may plateau above pre-AKI baseline, reflecting new CKD progression.",
      "clinical_implication": "KDIGO criteria still apply to proportional change; but absolute thresholds (e.g., >4.0 mg/dL) reached earlier",
      "cres_task": "Threshold detection: model must correctly apply KDIGO staging relative to elevated baseline"
    },
    {
      "variant_id": "aki_atyp_4",
      "name": "Delayed SCr rise (low muscle mass / liver disease)",
      "deviation": "SCr rise blunted due to reduced creatinine generation (sarcopenia, cirrhosis). AKI severity underestimated.",
      "clinical_implication": "Cystatin C or novel biomarkers more reliable in this population",
      "cres_task": "Contrastive: model must recognise that 'normal' SCr can mask severe AKI"
    },
    {
      "variant_id": "aki_atyp_5",
      "name": "Rhabdomyolysis-associated AKI",
      "deviation": "SCr rises disproportionately fast (CK release adds to creatinine pool). Very high K⁺ and phosphate early. Myoglobin casts in urine.",
      "clinical_implication": "SCr rise partly artifactual (muscle creatine release); but kidney injury is real (cast nephropathy)",
      "cres_task": "Diagnostic consistency: model must integrate CK, SCr, and UO to correctly attribute AKI cause"
    },
    {
      "variant_id": "aki_atyp_6",
      "name": "Non-recovery / AKD transition",
      "deviation": "SCr does not decline by day 7; meets AKD criteria (persistent abnormality 7-90 days). May require long-term RRT.",
      "clinical_implication": "Transition from AKI to AKD; higher CKD conversion risk",
      "cres_task": "Temporal reasoning: model must identify non-recovery trajectory and flag AKD transition"
    }
  ]
