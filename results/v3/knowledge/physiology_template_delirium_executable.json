  "atypical_variants": [
    {
      "variant_id": "del_atyp_1",
      "name": "Purely hypoactive delirium (missed delirium)",
      "prevalence": "~43% of ICU delirium; most commonly missed subtype",
      "deviation": "No agitation, no psychomotor excitement. Patient appears withdrawn, drowsy, apathetic. RASS −1 to −3 but NOT sedation-related.",
      "clinical_implication": "Often mistaken for depression, fatigue, or oversedation. Carries WORSE prognosis than hyperactive.",
      "cres_task": "Contrastive: model must distinguish hypoactive delirium from appropriate sedation or depression"
    },
    {
      "variant_id": "del_atyp_2",
      "name": "Persistent delirium (>7 days)",
      "prevalence": "20-30% of ICU delirium episodes",
      "deviation": "CAM-ICU remains positive beyond 7 days. No resolution phase. May evolve into chronic cognitive impairment.",
      "clinical_implication": "Associated with dementia predisposition, higher mortality, longer ICU stay",
      "cres_task": "Temporal reasoning: model must identify non-resolving trajectory and predict persistence"
    },
    {
      "variant_id": "del_atyp_3",
      "name": "Delirium superimposed on dementia",
      "prevalence": "Common in elderly ICU patients (>65 years)",
      "deviation": "Baseline cognitive impairment present. Fluctuation less pronounced. CAM-ICU Feature 1 (inattention) may be chronically present. New-onset disorganised thinking is the key distinguishing feature.",
      "clinical_implication": "Higher delirium risk; worse outcomes; harder to detect",
      "cres_task": "Diagnostic consistency: model must separate chronic dementia features from acute delirium features"
    },
    {
      "variant_id": "del_atyp_4",
      "name": "Alcohol withdrawal delirium (delirium tremens)",
      "prevalence": "Subset of hyperactive delirium",
      "deviation": "Hyperadrenergic state: tremor, diaphoresis, seizures. Very high HR and BP. Distinct from typical ICU delirium trajectory — follows withdrawal timeline (24-72h after last drink).",
      "clinical_implication": "Requires benzodiazepines (unlike standard delirium where benzos are harmful)",
      "cres_task": "Contrastive: model must recognise that benzodiazepines are THERAPEUTIC here but CAUSATIVE in typical delirium"
    },
    {
      "variant_id": "del_atyp_5",
      "name": "Rapid-cycling mixed subtype",
      "prevalence": "~55% of ICU delirium (most common subtype)",
      "deviation": "RASS alternates between positive and negative within hours. Shifts from agitation to withdrawal unpredictably.",
      "clinical_implication": "Hardest to manage; medication titration challenging",
      "cres_task": "Temporal grounding: model must recognise rapid RASS oscillation as mixed delirium, not artefact"
    }
  ]
