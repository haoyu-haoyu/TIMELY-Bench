{
  "title": "ConditionGraph",
  "type": "object",
  "required": ["graph_name", "version", "condition", "nodes", "edges", "sources", "metadata"],
  "properties": {
    "graph_name": { "type": "string" },
    "version": { "type": "string" },
    "condition": { "type": "string" },
    "description": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "label"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["structured_indicator", "pattern_event", "text_evidence", "condition"]
          },
          "label": { "type": "string" },
          "domain": {
            "type": "string",
            "description": "Clinical domain category for the node (used to align with guideline concepts such as labs/vitals/symptoms/medications/multimorbidity).",
            "enum": [
              "lab_marker",
              "vital_sign",
              "symptom",
              "medication",
              "multimorbidity",
              "condition",
              "text_evidence",
              "other"
            ]
          },
          "feature": { "type": "string" },
          "threshold": { "type": ["number", "string"] },
          "direction": { "type": "string" },
          "unit": { "type": "string" },
          "severity": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "relation"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "relation": {
            "type": "string",
            "enum": ["triggers", "supports", "contradicts", "temporal_precedes", "contributes_to", "aggregates"]
          },
          "evidence": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "reference": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generated_by", "generated_at"],
      "properties": {
        "generated_by": { "type": "string" },
        "generated_at": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
