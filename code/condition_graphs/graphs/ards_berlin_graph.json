  "diagnostic_criteria": {
    "source": "Berlin Definition (JAMA 2012)",
    "pmid": "22797452",
    "required_criteria": [
      "Timing: Within 1 week of known clinical insult or worsening respiratory symptoms",
      "Chest imaging: Bilateral opacities not fully explained by effusions, lobar/lung collapse, or nodules",
      "Origin of edema: Respiratory failure not fully explained by cardiac failure or fluid overload",
      "Oxygenation: PaO2/FiO2 ≤ 300 mmHg with PEEP ≥ 5 cmH2O"
    ],
    "severity_classification": {
      "mild": "200 < PaO2/FiO2 ≤ 300 mmHg with PEEP or CPAP ≥ 5 cmH2O",
      "moderate": "100 < PaO2/FiO2 ≤ 200 mmHg with PEEP ≥ 5 cmH2O",
      "severe": "PaO2/FiO2 ≤ 100 mmHg with PEEP ≥ 5 cmH2O"
    }
  },
