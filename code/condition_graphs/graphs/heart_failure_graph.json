  "diagnostic_criteria": {
    "source": "ESC Guidelines for Acute and Chronic Heart Failure (2016)",
    "pmid": "27206819",
    "clinical_presentation": [
      "Symptoms: Dyspnea, orthopnea, paroxysmal nocturnal dyspnea, fatigue, ankle swelling",
      "Signs: Elevated JVP, hepatojugular reflux, pulmonary rales, peripheral edema",
      "Objective evidence: Elevated natriuretic peptides, structural/functional abnormality"
    ],
    "classification": {
      "HFrEF": "LVEF < 40% (Heart Failure with reduced Ejection Fraction)",
      "HFmrEF": "LVEF 40-49% (Heart Failure with mid-range EF)",
      "HFpEF": "LVEF ≥ 50% (Heart Failure with preserved EF)"
    },
    "acute_phenotypes": {
      "wet_warm": "Congestion without hypoperfusion",
      "wet_cold": "Congestion with hypoperfusion",
      "dry_warm": "No congestion, no hypoperfusion",
      "dry_cold": "No congestion but hypoperfusion"
    }
